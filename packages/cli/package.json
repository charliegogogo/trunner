{
  "name": "@trunner/cli",
  "version": "0.1.0",
  "description": "Cross-platform CLI for trunner (Ink TUI).",
  "license": "MIT",
  "type": "module",
  "bin": {
    "trunner": "./dist/trunner.mjs"
  },
  "main": "./dist/trunner.mjs",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/trunner.tsx",
    "test": "vitest run",
    "test:unit": "vitest run --dir test/unit",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: not yet configured'",
    "clean": "rm -rf dist coverage .tsbuildinfo",
    "build:sea:macos": "bash scripts/build-sea.sh",
    "build:sea:linux": "bash scripts/build-sea.sh",
    "build:sea:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-sea.ps1"
  },
  "dependencies": {
    "@trunner/sdk": "workspace:*",
    "ansi-to-react": "^6.2.6",
    "ink": "^7.0.4",
    "meow": "^14.1.0",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
