{
  "name": "@trunner/sdk",
  "version": "0.1.0",
  "description": "Core SDK for trunner: Tool abstraction, runner, installer, and Terraform implementation.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:unit": "vitest run --dir test/unit",
    "test:integration": "vitest run --dir test/integration",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: not yet configured'",
    "clean": "rm -rf dist coverage .tsbuildinfo"
  },
  "dependencies": {
    "@cdktf/hcl2json": "^0.21.0",
    "adm-zip": "^0.5.17",
    "smol-toml": "^1.6.1",
    "tar": "^7.5.11"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
